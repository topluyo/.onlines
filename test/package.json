{
  "name": "onlines-stress-test",
  "version": "1.0.0",
  "description": "Stress test for !onlines WebSocket server",
  "main": "stress.js",
  "scripts": {
    "test": "node stress.js",
    "test:1k": "node stress.js --connections=1000 --batch=100 --delay=50",
    "test:5k": "node stress.js --connections=5000 --batch=200 --delay=30",
    "test:10k": "node stress.js --connections=10000 --batch=500 --delay=20"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
